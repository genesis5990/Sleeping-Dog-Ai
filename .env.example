# Sleeping Dog Ai - environment configuration
# Copy to .env.local and fill in.

# --- Supabase (Sleeping Dog Ai project) -----------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://kvwabkhnhskzzibddslw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_p6UVlLp8E0sgZxPpf9wMSw_Cb2lYrl3
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- RunPod vLLM serverless endpoint --------------------------------------
# Server-side only. NEVER prefix with NEXT_PUBLIC_.
# Endpoint ID shown on the RunPod endpoint detail page.
RUNPOD_ENDPOINT_ID=replace-with-endpoint-id
# RunPod API key (https://docs.runpod.io/get-started/api-keys)
RUNPOD_API_KEY=replace-with-runpod-api-key
# Model identifier — must match what vLLM is serving.
# Either the HF repo (e.g. meta-llama/Llama-3.1-8B-Instruct) or the value
# you set via OPENAI_SERVED_MODEL_NAME_OVERRIDE on the endpoint.
RUNPOD_MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
# Optional: override base URL (defaults to https://api.runpod.ai/v2/$RUNPOD_ENDPOINT_ID/openai/v1)
# RUNPOD_BASE_URL=
